---
import { SITE } from '../config';
---
<section class="pullquote-section" aria-label="quote">
  <div class="inner">
    <div class="pullquote-mark reveal" aria-hidden="true"></div>
    <p class="pullquote reveal">להפסיק להיות הכבאי של העסק.<br /><em>להתחיל לנווט אותו.</em></p>
    <div class="pullquote-cta reveal">
      <a
        href={SITE.calUrl}
        class="pullquote-btn"
        target="_blank"
        rel="noopener noreferrer"
        data-cal-link={SITE.calLink}
      >לקביעת שיחת התאמה</a>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .pullquote-section {
    border-top: 1px solid var(--line);
    padding: 80px 24px;
    background: var(--cream-2);
    position: relative;
  }

  .inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .pullquote-mark {
    width: 36px;
    height: 1px;
    background: var(--bronze);
    margin: 0 auto 32px;
    opacity: 0.55;
  }

  .pullquote {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: clamp(26px, 6vw, 50px);
    line-height: 1.28;
    color: var(--dark);
    letter-spacing: -0.025em;
  }

  .pullquote em {
    font-style: italic;
    font-weight: 300;
    color: var(--mid);
  }

  .pullquote-cta {
    margin-top: 40px;
  }

  .pullquote-btn {
    display: inline-flex;
    align-items: center;
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--cream);
    background: var(--dark);
    padding: 15px 36px;
    min-height: 44px;
    transition: background 0.2s, transform 0.2s;
  }
  .pullquote-btn:hover {
    background: var(--bronze);
    transform: translateY(-1px);
  }

  /* tablet */
  @media (min-width: 768px) {
    .pullquote-section { padding: 100px 40px; }
    .pullquote { font-size: clamp(28px, 4.5vw, 50px); }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .pullquote-section { padding: 130px 52px; }
    .pullquote { font-size: clamp(28px, 3.8vw, 50px); }
  }
</style>
