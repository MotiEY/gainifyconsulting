---
---
<section class="proof-strip">
  <div class="inner">
    <div class="proof-item">
      <span class="proof-num">26</span>
      <span class="proof-headline">שנות ניהול בכיר</span>
      <span class="proof-detail">לקוחות · תקציבים · אנשים</span>
    </div>
    <div class="proof-divider" aria-hidden="true"></div>
    <div class="proof-item">
      <span class="proof-num">8</span>
      <span class="proof-headline">שנים בארה"ב</span>
      <span class="proof-detail">ארגונים גלובליים Fortune 500</span>
    </div>
    <div class="proof-divider" aria-hidden="true"></div>
    <div class="proof-item">
      <span class="proof-num">7</span>
      <span class="proof-headline">הלבנים של כל עסק</span>
      <span class="proof-detail">שיטת 7BRICKS</span>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .proof-strip {
    background: var(--dark);
    padding: 44px 24px;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .proof-divider {
    height: 1px;
    background: rgba(240,234,224,0.1);
    margin: 4px 0;
  }

  .proof-item {
    padding: 22px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .proof-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: 52px;
    color: var(--cream);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 4px;
  }

  .proof-headline {
    font-family: 'Assistant', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: var(--cream);
    letter-spacing: 0.01em;
    line-height: 1.35;
  }

  .proof-detail {
    font-family: 'Assistant', sans-serif;
    font-weight: 300;
    font-size: 13px;
    color: rgba(240,234,224,0.5);
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  /* tablet+ */
  @media (min-width: 768px) {
    .proof-strip { padding: 56px 40px; }

    .inner {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: stretch;
    }

    .proof-divider {
      width: 1px;
      height: auto;
      background: rgba(240,234,224,0.12);
      margin: 0;
    }

    .proof-item {
      padding: 8px 40px;
    }
    .proof-item:first-child { padding-inline-start: 0; }
    .proof-item:last-child  { padding-inline-end: 0; }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .proof-strip { padding: 64px 52px; }
    .proof-num   { font-size: 60px; }
    .proof-headline { font-size: 16px; }
    .proof-detail { font-size: 13.5px; }
    .proof-item { padding: 8px 56px; }
  }
</style>
