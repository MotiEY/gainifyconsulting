---
---
<section class="proof-strip">
  <div class="inner">
    <div class="proof-item">
      <span class="proof-num">26</span>
      <span class="proof-label">שנות ניהול בסביבות מורכבות</span>
    </div>
    <div class="proof-divider" aria-hidden="true"></div>
    <div class="proof-item">
      <span class="proof-num">7</span>
      <span class="proof-label">תחומים בעסק — מבט אחד שלם</span>
    </div>
    <div class="proof-divider" aria-hidden="true"></div>
    <div class="proof-item">
      <span class="proof-num">1</span>
      <span class="proof-label">פגישת מיפוי שמתחילה את הדרך</span>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .proof-strip {
    background: var(--dark);
    padding: 44px 24px;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .proof-divider {
    height: 1px;
    background: rgba(240,234,224,0.1);
    margin: 4px 0;
  }

  .proof-item {
    padding: 20px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .proof-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: 52px;
    color: var(--cream);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .proof-label {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: rgba(240,234,224,0.5);
  }

  /* tablet+ */
  @media (min-width: 768px) {
    .proof-strip { padding: 52px 40px; }

    .inner {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: center;
    }

    .proof-divider {
      width: 1px;
      height: 52px;
      background: rgba(240,234,224,0.12);
      margin: 0;
    }

    .proof-item {
      padding: 0 48px;
    }
    .proof-item:first-child { padding-inline-start: 0; }
    .proof-item:last-child  { padding-inline-end: 0; }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .proof-strip { padding: 56px 52px; }
    .proof-num   { font-size: 60px; }
    .proof-label { font-size: 14px; }
  }
</style>
