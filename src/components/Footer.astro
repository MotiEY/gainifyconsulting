---
import { SITE } from '../config';

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="inner">
    <span class="footer-brand">{SITE.name} · {SITE.tagline}</span>
    <nav class="footer-links" aria-label="קישורי פוטר">
      <ul>
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></li>
        <li><a href="/nigshu">הצהרת נגישות</a></li>
      </ul>
    </nav>
    <span class="footer-copy">© {year} Moti Sadot · מוטי שדות</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    border-top: 1px solid rgba(240, 234, 224, 0.05);
    padding: 36px 24px;
  }

  .site-footer .inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-brand {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    color: rgba(240, 234, 224, 0.6);
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    color: rgba(240, 234, 224, 0.45);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  @media (hover: hover) {
    .footer-links a:hover { color: rgba(240, 234, 224, 0.6); }
  }

  .footer-copy {
    font-family: 'Assistant', sans-serif;
    font-size: 11px;
    color: rgba(240, 234, 224, 0.35);
  }

  @media (min-width: 768px) {
    .site-footer { padding: 40px 52px; }

    .site-footer .inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    .footer-links { gap: 32px; }
  }
</style>
