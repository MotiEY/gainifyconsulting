<section class="anchor-section" aria-label="מה מוטי מביא">
  <div class="anchor-inner">
    <p class="anchor-quote reveal">
      26 שנה בניהול מלמד דבר אחד:<br />
      <em>מה שצועק הכי חזק לא תמיד הדבר שצריך לטפל בו.</em>
    </p>
  </div>
</section>

<style>
  .anchor-section {
    background: var(--dark);
    padding: 72px 24px;
  }

  .anchor-inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .anchor-quote {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: clamp(24px, 5.5vw, 44px);
    line-height: 1.35;
    color: var(--cream-dk);
    letter-spacing: -0.025em;
  }

  .anchor-quote em {
    font-style: italic;
    color: var(--gold);
  }

  @media (min-width: 768px) {
    .anchor-section { padding: 96px 40px; }
  }

  @media (min-width: 1280px) {
    .anchor-section { padding: 120px 52px; }
    .anchor-quote { font-size: clamp(30px, 3.2vw, 44px); }
  }
</style>
