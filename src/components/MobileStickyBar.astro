---
import { SITE } from '../config';

const waUrl = `https://wa.me/${SITE.phone.replace('+', '')}`;
---

<div class="mobile-bar" role="region" aria-label="קישורי יצירת קשר מהירים">
  <a
    href={waUrl}
    class="bar-btn bar-wa"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="שלח הודעת וואטסאפ"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.857L.054 23.454a.75.75 0 0 0 .918.918l5.633-1.476A11.942 11.942 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.708 9.708 0 0 1-4.953-1.355l-.355-.211-3.683.965.981-3.595-.232-.371A9.718 9.718 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
    </svg>
    וואטסאפ
  </a>
  <a
    href={SITE.calUrl}
    class="bar-btn bar-cal"
    target="_blank"
    rel="noopener noreferrer"
    data-cal-link={SITE.calLink}
  >
    לקביעת שיחה
  </a>
</div>

<style>
  .mobile-bar {
    display: none;
  }

  @media (max-width: 767px) {
    .mobile-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      inset-inline: 0;
      z-index: 900;
      background: var(--cream);
      border-top: 1px solid var(--line);
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom));
      gap: 10px;
      transition: opacity 0.25s, transform 0.25s;
    }
    .mobile-bar.bar-hidden {
      opacity: 0;
      transform: translateY(100%);
      pointer-events: none;
    }

    .bar-btn {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      font-family: 'Assistant', sans-serif;
      font-size: 14px;
      font-weight: 500;
      min-height: 44px;
      border-radius: var(--r-btn);
      text-decoration: none;
      transition: opacity 0.2s, transform 0.15s;
    }
    .bar-btn:active { opacity: 0.82; transform: scale(0.97); }

    .bar-wa {
      background: #25D366;
      color: #fff;
    }

    .bar-cal {
      background: var(--dark);
      color: var(--cream-dk);
    }
  }
</style>

<script>
  const bar = document.querySelector('.mobile-bar');
  const heroActions = document.querySelector('.hero-actions');
  if (bar && heroActions) {
    const io = new IntersectionObserver(([entry]) => {
      bar.classList.toggle('bar-hidden', entry.isIntersecting);
    }, { threshold: 0.1 });
    io.observe(heroActions);
  }
</script>
