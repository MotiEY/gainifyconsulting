---
import { SITE } from '../config';
---
<section class="how-section" id="process">
  <div class="inner">
    <div class="how-top">
      <span class="tag reveal">איך זה עובד</span>
      <h2 class="how-heading reveal">שלושה שלבים. תמונה ברורה. דרך לפעולה.</h2>
    </div>

    <div class="how-steps">
      <div class="how-step reveal">
        <span class="step-num">01</span>
        <div class="step-body">
          <h3 class="step-title">שיחת התאמה קצרה</h3>
          <p class="step-time">15 דקות · ללא עלות</p>
          <p class="step-desc">בודקים יחד אם יש כאן התאמה. מה העסק עושה, איפה הוא עומד, ומה הדחיפות. אם יש בסיס נכון — ממשיכים.</p>
        </div>
      </div>

      <div class="how-connector" aria-hidden="true"></div>

      <div class="how-step reveal">
        <span class="step-num">02</span>
        <div class="step-body">
          <h3 class="step-title">דיאגנוסטיקה ומיפוי</h3>
          <p class="step-time">כשעתיים · אחד על אחד</p>
          <p class="step-desc">תמונה מלאה של העסק על פני שבעת התחומים. מה קורה היום, מה מעכב, ואיפה נקודת המנוף האמיתית.</p>
        </div>
      </div>

      <div class="how-connector" aria-hidden="true"></div>

      <div class="how-step reveal">
        <span class="step-num">03</span>
        <div class="step-body">
          <h3 class="step-title">תכנית עבודה מעשית</h3>
          <p class="step-time">תוצר בכתב · ניתן לביצוע</p>
          <p class="step-desc">כיוון ברור, סדר עדיפויות, ודרך עבודה שאפשר להתחיל לפעול לפיה. לא אסטרטגיה על הנייר — תוכנית שעובדת.</p>
        </div>
      </div>
    </div>

    <div class="how-cta reveal">
      <p class="how-cta-text">מוכנים לבדוק אם יש כאן התאמה?</p>
      <a
        href={SITE.calUrl}
        class="how-cta-btn"
        target="_blank"
        rel="noopener noreferrer"
        data-cal-link={SITE.calLink}
      >לקביעת שיחת התאמה קצרה</a>
    </div>
  </div>
</section>

<style>
  .how-section {
    background: var(--cream-2);
    padding: 72px 24px;
    border-top: 1px solid var(--line);
  }

  .inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .how-top {
    margin-bottom: 56px;
  }

  .how-heading {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 400;
    font-size: clamp(24px, 5vw, 38px);
    color: var(--text-h);
    line-height: 1.25;
    letter-spacing: -0.02em;
    max-width: 560px;
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .how-connector {
    width: 1px;
    height: 36px;
    background: var(--bronze);
    opacity: 0.3;
    margin-inline-start: 22px;
  }

  .how-step {
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }

  .step-num {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--bronze);
    letter-spacing: 0.1em;
    min-width: 24px;
    padding-top: 4px;
  }

  .step-body {
    flex: 1;
    padding-bottom: 8px;
  }

  .step-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 400;
    font-size: clamp(19px, 3vw, 24px);
    color: var(--text-h);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .step-time {
    font-family: 'Assistant', sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--bronze);
    font-weight: 500;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .step-desc {
    font-family: 'Assistant', sans-serif;
    font-size: 16px;
    line-height: 1.8;
    color: var(--mid);
  }

  .how-cta {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .how-cta-text {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 400;
    font-size: clamp(18px, 3vw, 24px);
    color: var(--text-h);
    letter-spacing: -0.01em;
  }

  .how-cta-btn {
    display: inline-flex;
    align-items: center;
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--cream-dk);
    background: var(--dark);
    padding: 14px 32px;
    min-height: 44px;
    border-radius: var(--r-btn);
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .how-cta-btn:hover {
    background: var(--bronze);
    transform: translateY(-1px);
  }

  @media (min-width: 768px) {
    .how-section { padding: 96px 40px; }
    .how-steps { flex-direction: row; align-items: flex-start; }
    .how-connector { width: 40px; height: 1px; margin-inline-start: 0; margin-top: 22px; flex-shrink: 0; }
    .how-step { flex-direction: column; flex: 1; }
    .how-cta { flex-direction: row; align-items: center; justify-content: space-between; }
  }

  @media (min-width: 1280px) {
    .how-section { padding: 120px 52px; }
    .how-connector { width: 64px; }
  }
</style>
