---
import { SITE } from '../config';
---
<section class="hero" id="top">
  <div class="inner">
    <div class="hero-content">
      <span class="tag">ייעוץ עסקי אסטרטגי · גישת 7BRICKS</span>
      <h1 class="hero-title reveal">מה שמרגיש הכי דחוף בעסק,<br class="hero-br" /> לא תמיד הדבר שהכי נכון לטפל בו.</h1>
      <p class="hero-promise reveal">אחרי 26 שנה בניהול מערכות מורכבות, למדתי שהתקדמות אמיתית מתחילה כשמבינים איפה נכון להשקיע זמן, כסף ואנרגיה. אני עוזר לבעלי עסקים בצמיחה ולהנהלות בכירות לזהות את נקודת המנוף, ולבנות דרך עבודה שאפשר לבצע.</p>
      <div class="hero-actions reveal">
        <a
          href={SITE.calUrl}
          class="hero-btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          data-cal-link={SITE.calLink}
        >לקביעת שיחת התאמה קצרה</a>
        <a
          href={`https://wa.me/${SITE.phone.replace('+','')}`}
          class="hero-btn-wa"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="וואטסאפ"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.857L.054 23.454a.75.75 0 0 0 .918.918l5.633-1.476A11.942 11.942 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.708 9.708 0 0 1-4.953-1.355l-.355-.211-3.683.965.981-3.595-.232-.371A9.718 9.718 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
          וואטסאפ
        </a>
      </div>
      <p class="hero-cta-note reveal">אם נראה שיש בסיס נכון להמשך, נתקדם לדיאגנוסטיקה עסקית מסודרת.</p>
    </div>

    <div class="hero-visual reveal">
      <div class="hero-photo-wrap">
        <img
          src="/moti-sadot.png"
          alt="מוטי שדות, יועץ עסקי אסטרטגי"
          width="480"
          height="640"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .hero {
    min-height: 100svh;
    padding: 0 24px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 28px,
      rgba(24,20,16,0.018) 28px,
      rgba(24,20,16,0.018) 29px
    );
    pointer-events: none;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
    padding: 100px 0 72px;
    width: 100%;
    position: relative;
  }

  .hero-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(33px, 7.5vw, 60px);
    line-height: 1.1;
    color: var(--text-h);
    margin-bottom: 24px;
    letter-spacing: -0.035em;
  }

  .hero-promise {
    font-family: 'Assistant', sans-serif;
    font-weight: 400;
    font-size: clamp(16px, 3vw, 19px);
    line-height: 1.75;
    color: var(--mid);
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--cream-dk);
    background: var(--dark);
    padding: 13px 28px;
    min-height: 44px;
    border-radius: var(--r-btn);
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .hero-btn-primary:hover { background: var(--bronze); transform: translateY(-1px); }

  .hero-btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    background: #25D366;
    padding: 13px 22px;
    min-height: 44px;
    border-radius: var(--r-btn);
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .hero-btn-wa:hover { background: #1ebe5d; transform: translateY(-1px); }

  .hero-cta-note {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    line-height: 1.65;
    color: var(--faint);
    margin-top: 14px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }

  .hero-stats span {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    color: var(--mid);
    letter-spacing: 0.01em;
  }

  .stat-dot {
    color: var(--bronze) !important;
    opacity: 0.5;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-photo-wrap {
    width: 100%;
    max-width: 220px;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    position: relative;
    border-radius: 4px;
    box-shadow: 0 20px 50px -20px rgba(122, 100, 69, 0.45);
  }

  .hero-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  @media (min-width: 768px) {
    .hero { padding: 0 40px; }
    .inner { padding: 110px 0 80px; gap: 56px; }
    .hero-photo-wrap { max-width: 260px; }
  }

  @media (min-width: 1280px) {
    .hero { padding: 0 52px; }
    .inner {
      grid-template-columns: 1fr 340px;
      gap: 80px;
      padding: 120px 0 100px;
    }
    .hero-title { font-size: clamp(44px, 4.8vw, 60px); }
    .hero-promise { font-size: clamp(17px, 1.4vw, 19px); }
    .hero-photo-wrap { max-width: 340px; }
  }
</style>
