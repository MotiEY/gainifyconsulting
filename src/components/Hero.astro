---
import { SITE } from '../config';
---
<section class="hero" id="top">
  <div class="inner">
    <div class="hero-content">
      <span class="tag">ייעוץ עסקי אסטרטגי · גישת 7BRICKS</span>
      <h1 class="hero-title reveal">מה שמרגיש הכי דחוף בעסק, לא תמיד הדבר שהכי נכון לטפל בו.</h1>
      <p class="hero-promise reveal">אחרי 26 שנה בניהול מערכות מורכבות, למדתי שהתקדמות אמיתית מתחילה כשמבינים איפה נכון להשקיע זמן, כסף ואנרגיה. אני עוזר לבעלי עסקים ולהנהלות לזהות את נקודת המנוף, ולבנות דרך עבודה שאפשר לבצע.</p>
      <div class="hero-actions reveal">
        <a
          href={SITE.calUrl}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          data-cal-link={SITE.calLink}
        >לקביעת שיחת התאמה קצרה</a>
        <a href="#how" class="btn-ghost">איך אני עובד</a>
      </div>
      <p class="hero-cta-note reveal">אם נראה שיש בסיס נכון להמשך, נתקדם לדיאגנוסטיקה עסקית מסודרת.</p>
    </div>

    <div class="hero-visual reveal">
      <div class="hero-photo-wrap">
        <img
          src="/moti-hero.jpg"
          alt="מוטי שדות, יועץ עסקי אסטרטגי"
          width="480"
          height="640"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .hero {
    min-height: 100svh;
    padding: 0 24px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 28px,
      rgba(24,20,16,0.018) 28px,
      rgba(24,20,16,0.018) 29px
    );
    pointer-events: none;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
    padding: 100px 0 72px;
    width: 100%;
    position: relative;
  }

  .hero-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(34px, 8vw, 72px);
    line-height: 1.08;
    color: var(--dark);
    margin-bottom: 28px;
    letter-spacing: -0.035em;
  }

  .hero-promise {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: clamp(17px, 3.5vw, 23px);
    line-height: 1.6;
    color: var(--mid);
    margin-bottom: 40px;
    letter-spacing: -0.01em;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-cta-note {
    font-family: 'Assistant', sans-serif;
    font-size: 13px;
    line-height: 1.65;
    color: var(--faint);
    margin-top: 16px;
    letter-spacing: 0.01em;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-photo-wrap {
    width: 100%;
    max-width: 220px;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    position: relative;
  }

  .hero-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* tablet */
  @media (min-width: 768px) {
    .hero { padding: 0 40px; }
    .inner { padding: 110px 0 80px; gap: 56px; }
    .hero-photo-wrap { max-width: 260px; }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .hero { padding: 0 52px; }
    .inner {
      grid-template-columns: 1fr 320px;
      gap: 80px;
      padding: 120px 0 100px;
    }
    .hero-title { font-size: clamp(44px, 5.8vw, 72px); }
    .hero-promise { font-size: clamp(19px, 1.8vw, 23px); }
    .hero-photo-wrap { max-width: 320px; }
  }
</style>
