<section class="hero" id="top">
  <div class="inner">
    <div class="hero-content">
      <span class="tag">ייעוץ עסקי אסטרטגי · גישת 7BRICKS</span>
      <h1 class="hero-title reveal">הסיבה שנראית הכי ברורה, לרוב אינה הסיבה האמיתית.</h1>
      <p class="hero-promise reveal">אני עוזר לבעלי עסקים ולהנהלות להבין מה באמת מעכב את העסק, לזקק את העיקר, ולבנות דרך מעשית לצמיחה.</p>
      <div class="hero-actions reveal">
        <a href="#diagnostic" class="btn-primary">לתיאום פגישת מיפוי</a>
        <a href="#how" class="btn-ghost">איך אני עובד</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <svg class="hero-network-svg" viewBox="0 0 300 360" xmlns="http://www.w3.org/2000/svg">
        <line class="anim-line" x1="60"  y1="52"  x2="118" y2="108" stroke="rgba(106,94,80,0.18)" stroke-width="1.2" style="--len:80; --delay:0.15s"/>
        <line class="anim-line" x1="210" y1="38"  x2="118" y2="108" stroke="rgba(106,94,80,0.18)" stroke-width="1.2" style="--len:107; --delay:0.3s"/>
        <line class="anim-line" x1="118" y1="108" x2="152" y2="178" stroke="rgba(122,100,69,0.45)" stroke-width="1.5" style="--len:76; --delay:0.55s"/>
        <line class="anim-line" x1="252" y1="124" x2="152" y2="178" stroke="rgba(106,94,80,0.18)" stroke-width="1.2" style="--len:114; --delay:0.6s"/>
        <line class="anim-line" x1="152" y1="178" x2="72"  y2="248" stroke="rgba(122,100,69,0.45)" stroke-width="1.5" style="--len:101; --delay:0.9s"/>
        <line class="anim-line" x1="152" y1="178" x2="234" y2="256" stroke="rgba(106,94,80,0.18)" stroke-width="1.2" style="--len:107; --delay:0.95s"/>
        <line class="anim-line" x1="72"  y1="248" x2="150" y2="318" stroke="rgba(106,94,80,0.14)" stroke-width="1"   style="--len:94;  --delay:1.2s"/>

        <circle class="anim-dot" cx="60"  cy="52"  r="3"   fill="rgba(106,94,80,0.28)" style="--delay:0.12s"/>
        <circle class="anim-dot" cx="210" cy="38"  r="2.5" fill="rgba(106,94,80,0.22)" style="--delay:0.28s"/>
        <circle class="anim-dot" cx="118" cy="108" r="4"   fill="rgba(106,94,80,0.30)" style="--delay:0.5s"/>
        <circle class="anim-dot" cx="252" cy="124" r="2.8" fill="rgba(106,94,80,0.20)" style="--delay:0.58s"/>
        <circle class="anim-dot" cx="234" cy="256" r="3.2" fill="rgba(106,94,80,0.22)" style="--delay:1.0s"/>
        <circle class="anim-dot" cx="72"  cy="248" r="3.5" fill="rgba(122,100,69,0.30)" style="--delay:1.1s"/>
        <circle class="anim-dot" cx="150" cy="318" r="2.5" fill="rgba(106,94,80,0.16)" style="--delay:1.28s"/>

        <circle class="anim-dot pulse" cx="152" cy="178" r="6.5" fill="#7A6445" style="--delay:0.82s"/>
        <circle class="anim-dot" cx="152" cy="178" r="12" fill="none" stroke="#7A6445" stroke-width="1" opacity="0.18" style="--delay:0.98s"/>

        <text class="anim-dot" x="70"  y="49"  font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:0.35s">שיווק</text>
        <text class="anim-dot" x="216" y="35"  font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:0.48s">מכירות</text>
        <text class="anim-dot" x="124" y="105" font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:0.68s">תפעול</text>
        <text class="anim-dot" x="258" y="121" font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:0.75s">אנשים</text>
        <text class="anim-dot" x="160" y="175" font-family="Assistant, sans-serif" font-size="8" fill="rgba(122,100,69,0.8)"  text-anchor="start" style="--delay:1.0s">פיננסים</text>
        <text class="anim-dot" x="78"  y="262" font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:1.22s">ניהול</text>
        <text class="anim-dot" x="240" y="269" font-family="Assistant, sans-serif" font-size="8" fill="rgba(106,94,80,0.55)" text-anchor="start" style="--delay:1.18s">צמיחה</text>
      </svg>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .hero {
    min-height: 100svh;
    padding: 0 24px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 28px,
      rgba(24,20,16,0.018) 28px,
      rgba(24,20,16,0.018) 29px
    );
    pointer-events: none;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
    padding: 100px 0 72px;
    width: 100%;
    position: relative;
  }

  .hero-title {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 900;
    font-size: clamp(34px, 8vw, 72px);
    line-height: 1.08;
    color: var(--dark);
    margin-bottom: 28px;
    letter-spacing: -0.035em;
  }

  .hero-promise {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: clamp(17px, 3.5vw, 23px);
    line-height: 1.6;
    color: var(--mid);
    margin-bottom: 40px;
    letter-spacing: -0.01em;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-network-svg {
    width: 100%;
    max-width: 200px;
  }

  /* tablet */
  @media (min-width: 768px) {
    .hero { padding: 0 40px; }
    .inner { padding: 110px 0 80px; gap: 56px; }
    .hero-network-svg { max-width: 260px; }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .hero { padding: 0 52px; }
    .inner {
      grid-template-columns: 1fr 340px;
      gap: 80px;
      padding: 120px 0 100px;
    }
    .hero-title { font-size: clamp(44px, 5.8vw, 72px); }
    .hero-promise { font-size: clamp(19px, 1.8vw, 23px); }
    .hero-network-svg { max-width: 300px; }
  }
</style>
