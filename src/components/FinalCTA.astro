---
import { SITE } from '../config';
---
<section class="cta-section" id="contact">
  <div class="inner">
    <span class="tag reveal">נדבר</span>
    <h2 class="cta-heading reveal">הצעד הראשון לא חייב להיות גדול. הוא רק צריך להיות אמיתי.</h2>
    <p class="cta-body reveal">שיחה ראשונית של 15 דקות תעזור לראות אם יש כאן התאמה. אם כן, נמשיך לפגישת המיפוי. אם לא, קיבלת שיחה קצרה אבל ישרה על העסק שלך.</p>
    <div class="cta-actions reveal">
      <a
        href={SITE.calUrl}
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer"
        data-cal-link={SITE.calLink}
      >לקביעת שיחת התאמה</a>
      <a href={`mailto:${SITE.email}`} class="btn-ghost">{SITE.email}</a>
    </div>
  </div>
</section>

<style>
  /* mobile-first base */
  .cta-section {
    border-top: 1px solid var(--line);
    padding: 80px 24px;
    background: var(--cream-2);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: -40%;
    background: radial-gradient(
      ellipse 50% 60% at 80% 50%,
      rgba(122,100,69,0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .inner {
    max-width: 620px;
    position: relative;
  }

  .cta-heading {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 400;
    font-size: clamp(26px, 6vw, 44px);
    color: var(--dark);
    margin-bottom: 22px;
    letter-spacing: -0.02em;
    line-height: 1.22;
  }

  .cta-body {
    font-family: 'Assistant', sans-serif;
    font-size: 17px;
    line-height: 1.88;
    color: var(--mid);
    margin-bottom: 48px;
  }

  .cta-actions {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  /* tablet */
  @media (min-width: 768px) {
    .cta-section { padding: 100px 40px; }
    .cta-heading { font-size: clamp(28px, 4.5vw, 44px); }
  }

  /* desktop */
  @media (min-width: 1280px) {
    .cta-section { padding: 120px 52px; }
    .cta-heading { font-size: clamp(28px, 3.4vw, 44px); }
  }
</style>
