---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import MobileStickyBar from '../components/MobileStickyBar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'מוטי שדות | ייעוץ עסקי אסטרטגי',
  description = 'מוטי שדות, ייעוץ עסקי אסטרטגי בגישת 7BRICKS. מיפוי, פיצוח ותכנית עבודה מעשית לבעלי עסקים והנהלות.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PBRKS79GP2"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PBRKS79GP2');
  </script>
  <link rel="canonical" href="https://motisadot.com/" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://motisadot.com/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="he_IL" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;700;900&family=Assistant:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Cal.com embed — auto-wires data-cal-link elements to popup -->
  <script is:inline>(function(C,A,L){let p=function(a,ar){a.q.push(ar)};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true}if(ar[0]===L){const api=function(){p(api,arguments)};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return}p(cal,ar)}})(window,"https://app.cal.com/embed/embed.js","init");
  Cal("init",{origin:"https://app.cal.com"});
  Cal("ui",{"styles":{"branding":{"brandColor":"#7A6445"}},"hideEventTypeDetails":false,"layout":"month_view"});</script>

  <slot name="head" />
  <!-- Apply saved a11y preferences immediately to prevent flash -->
  <script is:inline>
    (function() {
      try {
        var h = document.documentElement;
        var ts = parseInt(localStorage.getItem('a11y_textSize') || '0');
        if (ts === 1) h.classList.add('a11y-text-lg');
        if (ts === 2) h.classList.add('a11y-text-xl');
        if (localStorage.getItem('a11y_contrast') === '1') h.classList.add('a11y-high-contrast');
        if (localStorage.getItem('a11y_font')     === '1') h.classList.add('a11y-readable-font');
        if (localStorage.getItem('a11y_links')    === '1') h.classList.add('a11y-highlight-links');
        if (localStorage.getItem('a11y_anim')     === '1') h.classList.add('a11y-no-anim');
      } catch(e) {}
    })();
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">דלג לתוכן הראשי</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <AccessibilityWidget />
  <WhatsAppButton />
  <MobileStickyBar />

  <script>
    // Scroll-triggered header blur/shadow
    const hdr = document.getElementById('site-header');
    if (hdr) {
      window.addEventListener('scroll', () => {
        hdr.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });
    }

    // Reveal elements as they enter the viewport
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -24px 0px' });

    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // Cal.com popup is handled automatically via data-cal-link attributes.
    // No manual wiring needed.

    // GA4 conversion tracking — gtag is global via is:inline in <head>
    document.addEventListener('click', (e) => {
      const el = (e.target as Element).closest('a');
      if (!el || !el.href) return;
      const gtag = (window as unknown as { gtag?: (...a: unknown[]) => void }).gtag;
      if (!gtag) return;
      if (el.href.includes('wa.me') || el.href.includes('whatsapp')) {
        gtag('event', 'whatsapp_click');
      } else if ((el as HTMLAnchorElement).dataset.calLink || el.href.includes('cal.com')) {
        gtag('event', 'schedule_click');
      }
    });
  </script>
</body>
</html>
