---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="בלוג | מוטי שדות"
  description="מחשבות על ניהול, אסטרטגיה ועסקים מבעד לעדשה של 26 שנות ניסיון"
>
  <section class="blog-page">
    <div class="page-inner">
      <h1 class="page-heading">בלוג</h1>

      {posts.length === 0 ? (
        <p class="empty-state">בקרוב יופיעו כאן מחשבות וכתבים</p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding: 100px 24px 80px;
    min-height: calc(100vh - 60px);
  }

  .page-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .page-heading {
    font-family: 'Frank Ruhl Libre', serif;
    font-weight: 300;
    font-size: clamp(36px, 6vw, 64px);
    color: var(--dark);
    margin-bottom: 48px;
    letter-spacing: -0.02em;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .empty-state {
    font-family: 'Assistant', sans-serif;
    font-size: 17px;
    color: var(--faint);
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  @media (min-width: 768px) {
    .blog-page { padding: 120px 40px 100px; }

    .blog-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0 48px;
    }
  }

  @media (min-width: 1280px) {
    .blog-page { padding: 140px 52px 100px; }

    .blog-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0 48px;
    }
  }
</style>
